# API (services/api)
DATABASE_URL=mysql://user:password@127.0.0.1:3306/magazine
PORT=4001
NODE_ENV=development

# Optional: Redis for caching
# REDIS_URL=redis://127.0.0.1:6379

# Optional: S3/MinIO for production storage
# STORAGE_PROVIDER=minio
# STORAGE_ENDPOINT=127.0.0.1:9000
# STORAGE_BUCKET=magazine
# STORAGE_ACCESS_KEY=minioadmin
# STORAGE_SECRET_KEY=minioadmin

# Optional: JWT secrets (use long random strings in production)
# JWT_ACCESS_SECRET=your-access-secret-min-10-chars
# JWT_REFRESH_SECRET=your-refresh-secret-min-10-chars

# Login brute-force limit (default 10 per RATE_LIMIT_WINDOW_MS, usually 15 min).
# Login limiting is skipped when NODE_ENV=development.
# Set to 0 to disable login rate limiting (e.g. staging only — not for production).
# LOGIN_RATE_LIMIT_MAX=50
