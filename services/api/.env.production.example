NODE_ENV=production
PORT=2034

# Use mysql service name inside docker network
DATABASE_URL=mysql://root:change_me@mysql:3306/magazine
REDIS_URL=redis://redis:6379

# Public base URL for generated links
API_BASE_URL=https://readerapi.vidhyavibe.in

# Storage
STORAGE_PROVIDER=minio
STORAGE_ENDPOINT=minio:9000
STORAGE_BUCKET=magazine
STORAGE_ACCESS_KEY=minio
STORAGE_SECRET_KEY=change_me

# JWT (minimum 10 chars)
JWT_ACCESS_SECRET=replace_with_secure_access_secret
JWT_REFRESH_SECRET=replace_with_secure_refresh_secret
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Security / limits
BCRYPT_SALT_ROUNDS=10
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=1000
LOGIN_RATE_LIMIT_MAX=10

# Optional worker
# RUN_DISPATCH_WORKER=true
# DISPATCH_WORKER_INTERVAL_MS=600000

# Optional payments
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=
