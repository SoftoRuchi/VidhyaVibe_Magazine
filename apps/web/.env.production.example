NODE_ENV=production
PORT=1034

# API URL consumed by web app (if needed in fetch layer)
# Set when building the web image (split deploy). Compose uses http://api:2034 internally.
NEXT_PUBLIC_API_BASE_URL=https://readerapi.vidhyavibe.in

# Razorpay publishable key used by reader payment page
NEXT_PUBLIC_RAZORPAY_KEY_ID=replace_with_razorpay_key
