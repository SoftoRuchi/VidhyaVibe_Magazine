# Admin app (apps/admin) — copy to .env.local for local dev

PORT=3034

# Proxy /api/* to the API (local dev: API on port 4001)
# NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:4001

# "Read Magazine" opens this site (default: production reader)
NEXT_PUBLIC_READER_URL=https://reader.vidhyavibe.in

# Use local web reader while developing:
# NEXT_PUBLIC_READER_URL=http://localhost:3000
