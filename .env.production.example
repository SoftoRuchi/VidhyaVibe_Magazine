NODE_ENV=production

# Ports used inside containers (compose overrides per service where needed)
PORT=2034

# Infrastructure
MYSQL_ROOT_PASSWORD=change_me
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=change_me
REDIS_URL=redis://redis:6379

# API
DATABASE_URL=mysql://root:change_me@mysql:3306/magazine
API_BASE_URL=https://readerapi.vidhyavibe.in
STORAGE_PROVIDER=minio
STORAGE_ENDPOINT=minio:9000
STORAGE_BUCKET=magazine
STORAGE_ACCESS_KEY=minio
STORAGE_SECRET_KEY=change_me
JWT_ACCESS_SECRET=replace_with_secure_access_secret
JWT_REFRESH_SECRET=replace_with_secure_refresh_secret
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d
BCRYPT_SALT_ROUNDS=10
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=1000
LOGIN_RATE_LIMIT_MAX=10
# RUN_DISPATCH_WORKER=true
# DISPATCH_WORKER_INTERVAL_MS=600000
RAZORPAY_KEY_ID=replace_with_razorpay_key_id
RAZORPAY_KEY_SECRET=replace_with_razorpay_key_secret

# Web/Admin public URLs
NEXT_PUBLIC_API_BASE_URL=https://readerapi.vidhyavibe.in
NEXT_PUBLIC_READER_URL=https://reader.vidhyavibe.in
NEXT_PUBLIC_RAZORPAY_KEY_ID=replace_with_razorpay_key
ADMIN_LOGIN_PATH=/admin/login
